from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import requests, re

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

SHEET_URL = "https://script.google.com/macros/s/AKfycbzQJkMpwfMzQu1Kv6Hj2WraLX1VsIFTudf63E_1KMjjkhnUEOZjOKc14TWc2286-qftWQ/exec"
user_sessions = {}

class ChatIn(BaseModel):
    user_id: str
    message: str

def normalize_doctor(msg: str) -> str:
    m = msg.strip().lower()
    mapping = {
        "nidhi": "Dr. Nidhi Singh (Gynecology)",
        "aditya": "Dr. Aditya Verma (High Risk Pregnancy)",
        "ankur": "Dr. Ankur Mehta (Emergency Care)",
    }
    return mapping.get(m, msg.strip())

def normalize_date(msg: str):
    s = msg.strip().replace("/", "-")
    return s if re.match(r"^\d{2}-\d{2}-\d{4}$", s) else None

def book_appointment(payload: dict) -> bool:
    try:
        r = requests.post(
            SHEET_URL,
            headers={"Content-Type": "text/plain;charset=utf-8"},
            json=payload,
            timeout=10
        )
        return r.ok
    except Exception:
        return False

def handle_message(user_id: str, message: str) -> str:
    if user_id not in user_sessions:
        user_sessions[user_id] = {"step": "start"}
    s = user_sessions[user_id]
    msg = message.strip()
    msg_lower = msg.lower()


    if msg.lower() in ["reset", "restart", "start over"]:
        user_sessions[user_id] = {"step": "start"}
        return "✅ Reset done. 👤 Your name?"

    if s["step"] == "start":
        s["step"] = "name"
        return "👤 Your name?"

    if s["step"] == "name":
        s["name"] = msg
        s["step"] = "phone"
        return "📞 Your phone number? (10 digits)"

    if s["step"] == "phone":
        digits = re.sub(r"\D", "", msg)
        if len(digits) < 10:
            return "❌ Phone number sahi daalo (10 digits)."
        s["phone"] = digits[-10:]
        s["step"] = "doctor"
        return "👨‍⚕️ Choose doctor: Nidhi / Aditya / Ankur"

    if s["step"] == "doctor":
        s["doctor"] = normalize_doctor(msg)
        s["step"] = "date"
        return "📅 Enter date (DD-MM-YYYY)"

    if s["step"] == "date":
        d = normalize_date(msg)
        if not d:
            return "❌ Date format galat. DD-MM-YYYY me bhejo."
        s["date"] = d

        payload = {
            "name": s["name"],
            "phone": s["phone"],
            "problem": "",
            "date": s["date"],
            "time": "",
            "doctor": s["doctor"],
            "payment_status": "Pending",
            "amount": "",
            "payment_mode": ""
        }

        ok = book_appointment(payload)
        user_sessions[user_id] = {"step": "start"}
        return "✅ Appointment booked 🎉" if ok else "❌ Booking failed, try again"


@app.post("/chat")
def chat_api(inp: ChatIn):
    return {"reply": handle_message(inp.user_id, inp.message)}


def is_booking_active(user_id):
    return user_id in user_sessions and user_sessions[user_id].get("step") != "start"
